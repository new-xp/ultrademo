# Ultrademo environment. Copy this file to .env (which is gitignored) and fill in
# what you need. Everything here is optional - the pipeline runs without a .env,
# it just falls back to a free placeholder voice and no auto-login.
#
#   cp .env.example .env

# --- Narration -------------------------------------------------------------
# Best voice: an ElevenLabs API key. Without it, the pipeline uses Piper
# (free, offline) or the macOS `say` placeholder. Unchanged lines are cached,
# so re-renders never re-bill your quota.
ELEVENLABS_API_KEY=

# Optional voice tuning (a built-in demo voice is used if unset):
# ELEVENLABS_VOICE_ID=UM3TOcm5kcELI84GFoAz
# ELEVENLABS_STABILITY=0.45

# --- App sign-in (optional) ------------------------------------------------
# For simple form logins, a flow's `setup` can read these instead of you
# pasting credentials into the chat. For SSO or anything with a human check,
# prefer `npm run login -- <profile> <url>` and sign in inside the window.
# APP_EMAIL=
# APP_PASSWORD=
